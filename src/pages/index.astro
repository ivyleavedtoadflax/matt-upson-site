---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Base title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <h1>Senior AI leadership for organisations that need expertise, not hype.</h1>
      <p class="hero-sub">I help public sector teams, not-for-profits, and growing companies figure out what to do with AI, and then do it.</p>
      <a href="/contact" class="btn btn--primary">Book a call</a>
    </div>
  </section>

  <!-- Services -->
  <section class="alt">
    <div class="container">
      <div class="grid-3">
        <div class="card">
          <h3>&ldquo;I need to figure out what to do with AI&rdquo;</h3>
          <p class="text-muted">AI strategy and roadmapping, discovery workshops, feasibility assessments. Honest guidance on what&rsquo;s realistic.</p>
          <a href="/services">Learn more &rarr;</a>
        </div>
        <div class="card">
          <h3>&ldquo;I need someone senior to lead the AI work&rdquo;</h3>
          <p class="text-muted">Fractional AI Lead / CTO, embedded technical leadership, team building. Senior expertise without the full-time hire.</p>
          <a href="/services">Learn more &rarr;</a>
        </div>
        <div class="card">
          <h3>&ldquo;I need an honest outside perspective&rdquo;</h3>
          <p class="text-muted">Technical due diligence, architecture review, vendor assessment, AI ethics and governance advisory.</p>
          <a href="/services">Learn more &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Writing -->
  <section>
    <div class="container">
      <h2>Recent writing</h2>
      <div class="grid-3 mt-3">
        {recentPosts.map(post => (
          <a href={`/writing/${post.id}`} class="card-link">
            <article class="card">
              <p class="text-muted" style="font-size:0.85rem;">
                {new Date(post.data.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'long' })}
              </p>
              <h3>{post.data.title}</h3>
              <p class="text-muted">{post.data.excerpt}</p>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Credibility -->
  <section class="alt">
    <div class="container text-center">
      <p class="credibility">Previously: Founder &amp; CEO at Mantis NLP &middot; Data Scientist at GDS &middot; Department for Education &middot; The Cabinet Office</p>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 6rem 0 5rem;
  }

  .hero-inner {
    max-width: 720px;
  }

  .hero h1 {
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .credibility {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
  }
</style>
