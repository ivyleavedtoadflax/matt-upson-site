---

<Base title="Archive" description="Everything I've written since 2014 — across Medium, Substack, government blogs, and machinegurning.blog.">
  <section>
    <div class="container--narrow">
      <h1>Archive</h1>
      <p class="lead mt-3">Everything I&rsquo;ve written since 2014 &mdash; across Medium, Substack, government blogs, and my old technical blog. For newer posts hosted here, see <a href="/writing">Writing</a>.</p>
    </div>
  </section>

  {archive.map(group => (
    <section class={group.year % 2 === 0 ? 'alt' : ''}>
      <div class="container--narrow">
        <h2>{group.year}</h2>
        <ul class="archive-list">
          {group.posts.map(post => (
            <li>
              <a href={post.url} target="_blank" rel="noopener">{post.title}</a>
              <span class="source">{post.source}{post.author ? ` \u00b7 ${post.author}` : ''}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}
</Base>

<style>
  .lead {
    font-size: 1.2rem;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .lead a {
    color: var(--color-accent);
  }

  .archive-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .archive-list a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .archive-list a:hover {
    color: var(--color-accent);
  }

  .source {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
