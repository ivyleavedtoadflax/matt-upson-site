---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title="Writing" description="Thinking out loud about AI, data, leadership, and government. No hype.">
  <section>
    <div class="container--narrow">
      <h1>Writing</h1>
      <p class="lead mt-3">Thinking out loud about AI, data, leadership, and government. No hype.</p>
      <p class="mt-2"><a href="https://reproducible.substack.com" target="_blank" rel="noopener">Subscribe on Substack &rarr;</a></p>
    </div>
  </section>

  <section class="alt">
    <div class="container">
      <div class="grid-2">
        {posts.map(post => (
          <a href={`/writing/${post.id}`} class="card-link">
            <article class="card">
              <p class="text-muted" style="font-size:0.85rem;">
                {new Date(post.data.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <h3>{post.data.title}</h3>
              <p class="text-muted">{post.data.excerpt}</p>
              <span class="read-more">Read &rarr;</span>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container--narrow">
      <h2>Selected talks</h2>
      <div class="card mt-3">
        <h3>All the mistakes I made as a first-time tech lead</h3>
        <p class="text-muted">PyData &middot; Leadership track</p>
        <p>An honest talk about the transition from individual contributor to tech leader in AI &mdash; the mistakes, the lessons, and what I&rsquo;d do differently.</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .lead {
    font-size: 1.2rem;
    color: var(--color-text-muted);
  }

  .card-link {
    text-decoration: none;
    color: inherit;
  }

  .read-more {
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.95rem;
  }
</style>
